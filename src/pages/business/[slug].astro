---
import "../../styles/global.css";
import { businesses, type Business } from "../../data/businesses";
import {
  formatPhone,
  getStatusLabel,
  localBusinessJsonLd,
  mapHref,
  phoneHref,
  websiteLabel,
} from "../../lib/business";

export function getStaticPaths() {
  return businesses.map((business) => ({
    params: { slug: business.slug },
    props: { business },
  }));
}

const { business } = Astro.props as { business: Business };
const schema = localBusinessJsonLd(business);
const pageTitle = `${business.name} | The Murray Highlighter`;
const pageDescription = `${business.name}: ${business.summary}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body class="detail-page">
    <a class="skip-link" href="#details">Skip to details</a>
    <header class="site-header site-header--plain" aria-label="Site header">
      <a class="brand-mark" href="/" aria-label="The Murray Highlighter home">
        <span class="brand-mark__stamp" aria-hidden="true">MH</span>
        <span class="brand-mark__text">The Murray Highlighter</span>
      </a>
      <nav class="nav-links" aria-label="Primary navigation">
        <a href="/#businesses">Businesses</a>
        <a href="/#advertise">Advertise</a>
      </nav>
    </header>

    <main id="details">
      <section class="detail-hero" aria-labelledby="business-name">
        <div class="section__inner detail-grid">
          <div>
            <p class="eyebrow">{business.category}</p>
            <h1 id="business-name">{business.name}</h1>
            <p>{business.summary}</p>
            {business.offer && <p class="offer">{business.offer}</p>}
            <div class="detail-actions">
              {business.phone && (
                <a class="button" href={phoneHref(business.phone)}>
                  Call {formatPhone(business.phone)}
                </a>
              )}
              {business.website && (
                <a class="text-button" href={business.website} target="_blank" rel="noreferrer">
                  Visit {websiteLabel(business.website)}
                </a>
              )}
              {business.address && (
                <a class="text-button" href={mapHref(business.address)} target="_blank" rel="noreferrer">
                  Open Map
                </a>
              )}
            </div>
          </div>

          <aside class="detail-panel" aria-label="Listing status">
            <h2>Listing Status</h2>
            <p>{getStatusLabel(business.verificationStatus)}</p>
            <p>
              Details are pulled from the postcard and linked public listings. Internal
              verification notes are not shown on public pages.
            </p>
          </aside>
        </div>
      </section>

      <section class="section" aria-labelledby="contact-heading">
        <div class="section__inner detail-grid">
          <div>
            <div class="section-heading">
              <h2 id="contact-heading">Contact Details</h2>
              <p>Use the fastest available contact method for this postcard listing.</p>
            </div>
            <dl class="detail-list">
              {business.phone && (
                <div>
                  <dt>Phone</dt>
                  <dd>
                    <a href={phoneHref(business.phone)}>{formatPhone(business.phone)}</a>
                  </dd>
                </div>
              )}
              {
                business.secondaryPhones?.map((phone) => (
                  <div>
                    <dt>{phone.label}</dt>
                    <dd>
                      <a href={phoneHref(phone.number)}>{formatPhone(phone.number)}</a>
                    </dd>
                  </div>
                ))
              }
              {business.email && (
                <div>
                  <dt>Email</dt>
                  <dd>
                    <a href={`mailto:${business.email}`}>{business.email}</a>
                  </dd>
                </div>
              )}
              {business.website && (
                <div>
                  <dt>Website</dt>
                  <dd>
                    <a href={business.website} target="_blank" rel="noreferrer">
                      {websiteLabel(business.website)}
                    </a>
                  </dd>
                </div>
              )}
              {business.address && (
                <div>
                  <dt>Address</dt>
                  <dd>
                    <a href={mapHref(business.address)} target="_blank" rel="noreferrer">
                      {business.address}
                    </a>
                  </dd>
                </div>
              )}
              {business.serviceArea && (
                <div>
                  <dt>Service area</dt>
                  <dd>{business.serviceArea}</dd>
                </div>
              )}
            </dl>
          </div>

          <aside>
            <div class="section-heading">
              <h2>Sources</h2>
              <p>Public links used to build this listing.</p>
            </div>
            <ul class="source-list">
              {
                business.sourceUrls.map((source) => (
                  <li>
                    {source.href ? (
                      <a
                        href={source.href}
                        target={source.href.startsWith("http") ? "_blank" : undefined}
                        rel="noreferrer"
                      >
                        {source.label}
                      </a>
                    ) : (
                      source.label
                    )}
                  </li>
                ))
              }
            </ul>
          </aside>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p>
          The Murray Highlighter by Influence Marketing. Business details are sourced
          from the postcard and public listings, then confirmed with advertisers when possible.
        </p>
        <a class="text-button" href="/#businesses">Back to directory</a>
      </div>
    </footer>
  </body>
</html>
